{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disableClaudeAiConnectors": true,
  "enableAllProjectMcpServers": false,
  "permissions": {
    "allow": [
      "Bash(wrangler d1 execute *)",
      "Bash(wrangler d1 migrations apply *)",
      "Bash(wrangler d1 export *)",
      "Bash(wrangler tail *)",
      "Bash(wrangler versions list *)",
      "Bash(wrangler versions upload *)",
      "Bash(wrangler versions deploy *)",
      "Bash(wrangler versions rollback *)",
      "Bash(wrangler rollback *)",
      "Bash(wrangler r2 object get *)",
      "Bash(wrangler r2 object put *)",
      "Bash(wrangler r2 object list *)",
      "Bash(wrangler deploy --dry-run *)",
      "Bash(gh pr view *)",
      "Bash(gh pr create *)",
      "Bash(gh pr list *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh run view *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(npm test *)",
      "Bash(npm run lint *)",
      "Bash(npx tsc --noEmit *)",
      "Bash(npx wrangler types *)",
      "Bash(node .github/scripts/diff-review.mjs *)",
      "Bash(rm -rf node_modules *)",
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf .wrangler *)",
      "Bash(rm -rf .wrangler)"
    ],
    "deny": [
      "Bash(git commit --no-verify *)",
      "Bash(git push --no-verify *)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push --force-with-lease)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf ..*)",
      "Bash(rm -rf $HOME*)"
    ]
  }
}
